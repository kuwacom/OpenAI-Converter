# OpenAI-Converter 設定
# このファイルをコピーして .env を作成してください(Node.js 実行時のみ読込)

# --- サーバ ---
# Node 実行時のリッスン先(Workers では wrangler.toml / 環境変数経由)
HOST=127.0.0.1
PORT=3000

# CORS 送信元。"*" で全許可、本番では具体ドメイン推奨
CORS_ORIGIN=*

# --- 上流 LLM API ---
# 上流は OpenAI 互換 Chat Completions(/v1/chat/completions) を前提。
# `/v1` まで含めたベースURLを指定すること。
UPSTREAM_BASE_URL=https://api.openai.com/v1

# 上流へ送信するモデル名。空文字なら request.model をそのまま転送する
UPSTREAM_MODEL=

# 上流認証用 API キー。ローカル検証でも外部APIを使う場合は必須。
# 外部ファイル/シークレットマネージャから注入しハードコードしないこと
UPSTREAM_API_KEY=

# --- バックエンド選択 ---
# openai-compatible-chat-completions : Chat Completions 上流を Responses API へ変換(既定)
# openai-compatible-responses        : ネイティブ Responses API 上流へのパススルー
DEFAULT_BACKEND=openai-compatible-chat-completions

# --- ログ ---
# silly | trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- ビルトイン web_search(SearXNG) ---
# 上流 LLM は Chat Completions のみのため web_search 組込みツールを持たない。
# proxy がリクエスト内 web_search 宣言を検知すると SearXNG 経由で代行実行する。
#
# SearXNG インスタンスのベースURL。空文字(既定)時は web_search 機能無効化扱い(stub fallback)
# 例: http://localhost:8888
WEB_SEARCH_SEARXNG_BASE_URL=

# 検索クエリ URL テンプレート。`<query>` プレースホルダ使用可。
# 指定時はベースURLより優先される。未指定なら `${SEARXNG_BASE_URL}/search?q=<query>&format=json`
WEB_SEARCH_SEARXNG_QUERY_URL=

# 検索言語。SearXNG の language パラメータへそのまま渡す(ja-JP/en-US 等)
WEB_SEARCH_SEARXNG_LANGUAGE=ja-JP

# X-Real-IP ヘッダー値。SearXNG 側の地域判別用に注入する(任意)
WEB_SEARCH_SEARXNG_CLIENT_IP=

# fetch User-Agent 文字列。SearXNG と取得先ページの両方で使用する
WEB_SEARCH_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36"

# search_context_size 既定/上限件数群(search/open_page/find_in_page 共通)
WEB_SEARCH_DEFAULT_LIMIT=10
WEB_SEARCH_MAX_LIMIT=25
WEB_SEARCH_FETCH_MAX_PAGES_PER_CALL=5

# タイムアウト(ms)。SearXNG 呼び出し本体とページ取得それぞれ個別に設ける
WEB_SEARCH_TIMEOUT_MS=15000
WEB_SEARCH_FETCH_TIMEOUT_MS=20000

# 取得ページのサイズ上限とテキスト抽出文字数上限。過大防止用
WEB_SEARCH_FETCH_MAX_BYTES=1500000
WEB_SEARCH_EXTRACT_CHAR_LIMIT=4000

# env 既定ユーザ位置情報群(位置補強不要時は全て空文字推奨)。
# リクエスト側 user_location 未指定時にのみこれらが参照され、検索語へ補強される
WEB_SEARCH_DEFAULT_USER_LOCATION_TYPE=
WEB_SEARCH_DEFAULT_USER_LOCATION_CITY=
WEB_SEARCH_DEFAULT_USER_LOCATION_REGION=
WEB_SEARCH_DEFAULT_USER_LOCATION_COUNTRY=
WEB_SEARCH_DEFAULT_USER_LOCATION_TIMEZONE=
